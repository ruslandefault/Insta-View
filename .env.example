# === Telegram ===
# @BotFather dan olingan token
BOT_TOKEN="123456:ABC-DEF..."
# Ixtiyoriy: markaziy akkaunt bloklansa xabar boradigan admin telegram_id
ADMIN_TELEGRAM_ID=

# === Markaziy (shared) Instagram akkaunt ===
# Foydalanuvchilar akkaunt kiritmaydi — barcha fetch shu akkaunt orqali.
IG_USERNAME=""
IG_PASSWORD=""
# Ixtiyoriy (TAVSIYA): parol o'rniga brauzer sessionid — login challenge bo'lmaydi.
# Olish: instagram.com ga kiring → DevTools → Application → Cookies → sessionid qiymati
IG_SESSIONID=""

# === Ma'lumotlar bazasi ===
# docker-compose ishlatilганda host = "db"
DATABASE_URL="postgresql+asyncpg://insta:insta@db:5432/instaview"

# === Shifrlash ===
# Fernet kaliti. Yangi kalit yaratish:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY="o'zgartiring-generatsiya-qiling"

# === Umumiy sozlamalar ===
DEFAULT_TZ="Asia/Tashkent"

# Scheduler har necha daqiqada "tick" qiladi
SCHEDULER_INTERVAL_MINUTES=30

# Instagram so'rovlari orasidagi tasodifiy kutish (soniya) — throttling
THROTTLE_MIN_SEC=3
THROTTLE_MAX_SEC=8

# "Yangilash" tugmasi cooldown (daqiqa)
REFRESH_COOLDOWN_MINUTES=5

# Telegram fayl chegarasi (MB) va siqish maqsadi (MB)
MAX_TELEGRAM_FILE_MB=50
TARGET_FILE_MB=45

# Log darajasi
LOG_LEVEL="INFO"
